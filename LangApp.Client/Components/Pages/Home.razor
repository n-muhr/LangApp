@page "/"

<PageTitle>LangApp - Home</PageTitle>

<div class="home-container">
    <header class="text-center">
        <h1>Welcome to lang learner</h1>
    </header>

    <div class="action-cards">
        <div class="card shadow-sm">
            <h3>Již máte účet?</h3>
            <p>Přihlaste se a pokračujte.</p>
            <a class="btn btn-primary" href="login">Přihlásit se</a>
        </div>

        <div class="card shadow-sm">
            <h3>Nový uživatel?</h3>
            <p>Vytvořte si účet.</p>
            <a class="btn btn-outline-success" href="register">Registrovat se</a>
        </div>
    </div>
</div>

<style>
    .home-container {
        max-width: 800px;
        margin: 50px auto;
        padding: 20px;
    }
    .action-cards {
        display: flex;
        gap: 20px;
        margin-top: 30px;
    }
    .card {
        flex: 1;
        padding: 20px;
        text-align: center;
        border: 1px solid #dee2e6;
        border-radius: 10px;
    }
</style>
